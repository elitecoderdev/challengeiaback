PORT=4000
DEFAULT_INGEST_LIMIT=25
DEFAULT_POOR_THRESHOLD=500

# Supabase persistence (required on Vercel)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STATE_TABLE=app_state
SUPABASE_STORE_KEY=launch-dashboard-state
SUPABASE_MAX_RETRIES=3
SUPABASE_RETRY_BASE_MS=400
SUPABASE_LOCAL_FALLBACK_ON_ERROR=1
